# Microsoft Entra app credentials (app registration 614e898f-16dc-4c39-adee-c5d148b6c788)
ENTRA_CLIENT_ID=614e898f-16dc-4c39-adee-c5d148b6c788
ENTRA_CLIENT_SECRET=<from Azure Key Vault: alterspective-draft-service--entra-secret>
ENTRA_TENANT_ID=<Alterspective tenant ID from Entra>

# API key — widget sends x-api-key header, store in Coolify env vars
API_KEY=<random secret>

# ── Sharedo tenant configuration ────────────────────────────────────────────
# Add one block per tenant. Pattern: TENANT_{ID_UPPER}_{KEY}
# The service uses OIDC session JWT login (not SCIM) for phase transitions.
#
# IMPORTANT: The USERNAME account must be a formal participant on any
# task-activity-prepare-document task before server-side generation works.
# Use the Sharedo UI "Take Ownership" button on the task first.

TENANT_AUSIAB_BASE_URL=https://ausiab.alterspective.com.au
TENANT_AUSIAB_IDENTITY_URL=https://id-ausiab.alterspective.com.au
TENANT_AUSIAB_USERNAME=ai@alterspective.com.au
TENANT_AUSIAB_PASSWORD=<from Azure Key Vault: ausiab--service-account-password>

# Add more tenants as needed:
# TENANT_PLAYWITHCLIO_BASE_URL=https://playwithclio.alterspective.com.au
# TENANT_PLAYWITHCLIO_IDENTITY_URL=https://id-playwithclio.alterspective.com.au
# TENANT_PLAYWITHCLIO_USERNAME=ai@alterspective.com.au
# TENANT_PLAYWITHCLIO_PASSWORD=<password>

# Tuning (optional — defaults shown)
POLL_TIMEOUT_MS=25000
POLL_INTERVAL_MS=2000

PORT=3000
